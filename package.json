{
  "name": "agentscope",
  "version": "0.1.0",
  "description": "Task-scoped runtime governance for AI coding agents: least-privilege scopes, runtime enforcement, evidence, deterministic risk scoring, and a local policy gate.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentscope": "./dist/index.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agents",
    "claude-code",
    "governance",
    "security",
    "policy",
    "audit",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentscope/agentscope.git"
  },
  "homepage": "https://github.com/agentscope/agentscope#readme",
  "bugs": {
    "url": "https://github.com/agentscope/agentscope/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-test.mjs",
    "agentscope": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picomatch": "^4.0.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/picomatch": "^3.0.2",
    "eslint": "^9.18.0",
    "typescript-eslint": "^8.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.9"
}
