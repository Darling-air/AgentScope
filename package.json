{
  "name": "agentscope",
  "version": "0.0.0",
  "description": "Least-privilege, task-scoped governance layer for AI coding agents (V0 prototype).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentscope": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "agentscope": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picomatch": "^4.0.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/picomatch": "^3.0.2",
    "eslint": "^9.18.0",
    "typescript-eslint": "^8.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.9"
}
